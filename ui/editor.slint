// BAppBuilder Code Editor — Slint UI
// Same primitive approach as HTML/JS: hidden input + colored spans + cursor overlay

// A single colored token within a line
export struct Token {
    text: string,
    color: color,
}

// A single line of code = array of colored tokens
export struct CodeLine {
    // We flatten tokens into fixed slots (Slint can't do nested for-loops on model arrays)
    // Instead, each line is pre-rendered as a single colored string per "segment"
    // Rust backend handles the tokenization and produces these
    full-text: string,
    line-number: int,
    is-active: bool,
}

// Individual token for rendering — flattened from all lines
// Each token knows its line index and x-offset for absolute positioning
export struct FlatToken {
    text: string,
    token-color: color,
    line-idx: int,
    x-offset: float,  // in character units (multiply by char-width)
}

// Editor theme colors
export global EditorTheme {
    // Background
    out property <color> bg-editor:          #0f0f1a;
    out property <color> bg-gutter:          #12121f;
    out property <color> bg-active-line:     #ffffff08;
    out property <color> bg-titlebar:        #12121f;
    out property <color> border-color:       #1e1e35;

    // Text
    out property <color> text-gutter:        #3a3a55;
    out property <color> text-gutter-active: #6a6a8a;
    out property <color> text-title:         #4a4a6a;
    out property <color> text-info:          #3a3a55;

    // Cursor
    out property <color> cursor-color:       #638cff;

    // Syntax colors (exposed so Rust can reference them)
    out property <color> syn-keyword:    #c678dd;
    out property <color> syn-string:     #98c379;
    out property <color> syn-number:     #d19a66;
    out property <color> syn-comment:    #5c6370;
    out property <color> syn-function:   #61afef;
    out property <color> syn-type:       #e5c07b;
    out property <color> syn-property:   #e06c75;
    out property <color> syn-operator:   #56b6c2;
    out property <color> syn-punctuation:#636d83;
    out property <color> syn-plain:      #abb2bf;
    out property <color> syn-bool:       #d19a66;
    out property <color> syn-builtin:    #56b6c2;
}

// ============================================================
// Line Number component — equivalent to gutter <div> in HTML
// ============================================================
component LineNumber inherits Rectangle {
    in property <int> number;
    in property <bool> active;
    
    width: 50px;
    height: 22px;
    
    Text {
        text: number;
        color: active ? EditorTheme.text-gutter-active : EditorTheme.text-gutter;
        font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace";
        font-size: 12px;
        horizontal-alignment: right;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
}

// ============================================================
// Single code line with up to 40 token slots
// This is the key insight: we use fixed slots like HTML spans
// Rust fills the slots, unused ones are hidden (empty text)
// ============================================================
component CodeLineView inherits Rectangle {
    in property <bool> is-active;
    // Token slots — each has text and color
    // We support up to 40 tokens per line (more than enough for most code)
    in property <string> t0;  in property <color> c0: EditorTheme.syn-plain;
    in property <string> t1;  in property <color> c1: EditorTheme.syn-plain;
    in property <string> t2;  in property <color> c2: EditorTheme.syn-plain;
    in property <string> t3;  in property <color> c3: EditorTheme.syn-plain;
    in property <string> t4;  in property <color> c4: EditorTheme.syn-plain;
    in property <string> t5;  in property <color> c5: EditorTheme.syn-plain;
    in property <string> t6;  in property <color> c6: EditorTheme.syn-plain;
    in property <string> t7;  in property <color> c7: EditorTheme.syn-plain;
    in property <string> t8;  in property <color> c8: EditorTheme.syn-plain;
    in property <string> t9;  in property <color> c9: EditorTheme.syn-plain;
    in property <string> t10; in property <color> c10: EditorTheme.syn-plain;
    in property <string> t11; in property <color> c11: EditorTheme.syn-plain;
    in property <string> t12; in property <color> c12: EditorTheme.syn-plain;
    in property <string> t13; in property <color> c13: EditorTheme.syn-plain;
    in property <string> t14; in property <color> c14: EditorTheme.syn-plain;
    in property <string> t15; in property <color> c15: EditorTheme.syn-plain;
    in property <string> t16; in property <color> c16: EditorTheme.syn-plain;
    in property <string> t17; in property <color> c17: EditorTheme.syn-plain;
    in property <string> t18; in property <color> c18: EditorTheme.syn-plain;
    in property <string> t19; in property <color> c19: EditorTheme.syn-plain;

    height: 22px;
    background: is-active ? EditorTheme.bg-active-line : transparent;
    
    HorizontalLayout {
        padding-left: 12px;
        spacing: 0px;
        
        Text { text: t0;  color: c0;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t1;  color: c1;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t2;  color: c2;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t3;  color: c3;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t4;  color: c4;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t5;  color: c5;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t6;  color: c6;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t7;  color: c7;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t8;  color: c8;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t9;  color: c9;  font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t10; color: c10; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t11; color: c11; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t12; color: c12; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t13; color: c13; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t14; color: c14; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t15; color: c15; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t16; color: c16; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t17; color: c17; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t18; color: c18; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
        Text { text: t19; color: c19; font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace"; font-size: 13px; vertical-alignment: center; }
    }
}

// ============================================================
// Main Editor Window
// ============================================================
export component CodeEditor inherits Window {
    title: "BAppBuilder — Code Editor";
    width: 900px;
    height: 600px;
    background: #1a1a2e;

    // === Model data from Rust ===
    in property <[CodeLine]> lines;
    
    // Flattened token model: Rust pushes ALL tokens for ALL lines into this flat array.
    // Each FlatToken knows which line it belongs to and its x-offset.
    // This avoids the nested for-loop problem entirely.
    in property <[FlatToken]> all-tokens;
    
    // Cursor position
    in property <int> cursor-line: 0;
    in property <int> cursor-col: 0;
    in property <float> char-width: 7.8;   // monospace char width in px
    in property <int> total-lines: 0;
    
    // Status
    in property <string> status-text: "Ln 1, Col 1";
    in property <string> language: "JavaScript";
    in property <string> file-name: "main.js";
    
    // === Callbacks to Rust ===
    callback key-pressed(string, bool, bool, bool);  // key, ctrl, shift, alt
    callback editor-clicked(float, float);            // x, y position
    callback text-input(string);                      // character input
    callback open-file();                             // native file dialog

    // Line height constant
    property <length> line-height: 22px;
    property <length> gutter-width: 56px;
    property <length> code-padding-left: 12px;

    VerticalLayout {
        // ========== Title bar ==========
        Rectangle {
            height: 38px;
            background: EditorTheme.bg-titlebar;
            
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                alignment: center;
                spacing: 8px;
                
                // Title
                Text {
                    text: root.file-name + " — BAppBuilder Runtime";
                    color: EditorTheme.text-title;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }
            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: EditorTheme.border-color;
            }
        }

        // ========== Toolbar ==========
        Rectangle {
            height: 32px;
            background: EditorTheme.bg-titlebar;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 12px;
                alignment: start;

                // Open button
                open-ta := TouchArea {
                    width: 72px;
                    height: 22px;
                    clicked => { root.open-file(); }
                    Rectangle {
                        border-radius: 4px;
                        background: open-ta.has-hover ? #2a2a45 : #1e1e38;
                        border-width: 1px;
                        border-color: EditorTheme.border-color;
                        Text {
                            text: "📂 Åbn";
                            color: #8888bb;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Language badge
                Text { text: root.language; color: EditorTheme.syn-keyword; font-size: 10px; font-weight: 600; vertical-alignment: center; }
                Text { text: "UTF-8"; color: EditorTheme.text-info; font-size: 10px; vertical-alignment: center; }
            }
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: EditorTheme.border-color;
            }
        }

        // ========== Editor body ==========
        Rectangle {
            background: EditorTheme.bg-editor;
            
            HorizontalLayout {
                // === Gutter (line numbers) ===
                Rectangle {
                    width: root.gutter-width;
                    background: EditorTheme.bg-gutter;
                    clip: true;
                    
                    // Gutter scrolls with the code area
                    VerticalLayout {
                        y: -flickable.viewport-y;
                        
                        for line[i] in root.lines : LineNumber {
                            number: line.line-number;
                            active: line.is-active;
                        }
                    }
                    
                    // Right border
                    Rectangle {
                        x: parent.width - 1px;
                        width: 1px;
                        background: EditorTheme.border-color;
                    }
                }

                // === Code area with scroll ===
                flickable := Flickable {
                    viewport-height: root.total-lines * 22px;
                    
                    // Click handler — send position to Rust
                    TouchArea {
                        clicked => {
                            root.editor-clicked(
                                self.mouse-x / 1px,
                                (self.mouse-y - flickable.viewport-y) / 1px
                            );
                        }
                    }
                    
                    // === Render all tokens using flat model ===
                    // Each token is absolutely positioned based on its line and x-offset
                    for token[i] in root.all-tokens : Text {
                        x: root.code-padding-left + (token.x-offset * root.char-width * 1px);
                        y: token.line-idx * root.line-height;
                        text: token.text;
                        color: token.token-color;
                        font-family: "Cascadia Code, JetBrains Mono, Consolas, monospace";
                        font-size: 13px;
                        height: root.line-height;
                        vertical-alignment: center;
                    }

                    // === Active line highlight ===
                    Rectangle {
                        x: 0;
                        y: root.cursor-line * root.line-height;
                        width: 100%;
                        height: root.line-height;
                        background: EditorTheme.bg-active-line;
                    }

                    // === Cursor (animated rectangle) ===
                    Rectangle {
                        x: root.code-padding-left + (root.cursor-col * root.char-width * 1px);
                        y: root.cursor-line * root.line-height + 3px;
                        width: 2px;
                        height: 16px;
                        background: EditorTheme.cursor-color;
                        
                        // Blink animation
                        property <bool> visible-state: true;
                        states [
                            on when visible-state: { opacity: 1.0; }
                            off when !visible-state: { opacity: 0.0; }
                        ]
                        animate opacity { duration: 500ms; }
                    }
                }
            }
            
            // === Hidden TextInput — keyboard capture ===
            // This is the exact same pattern as the HTML prototype's hidden <textarea>
            input := TextInput {
                x: -1000px;  // hidden off-screen
                width: 0;
                height: 0;
                
                // Capture text edits
                edited => {
                    root.text-input(self.text);
                    self.text = "";  // clear after processing
                }
                
                // Key events are handled through the FocusScope below
            }
        }
        
        // ========== Status bar ==========
        Rectangle {
            height: 26px;
            background: EditorTheme.bg-titlebar;
            
            Rectangle {
                y: 0;
                height: 1px;
                background: EditorTheme.border-color;
            }
            
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                alignment: space-between;
                
                Text { text: "NORMAL"; color: EditorTheme.text-info; font-size: 10px; vertical-alignment: center; }
                Text { text: root.status-text; color: EditorTheme.text-gutter-active; font-size: 10px; vertical-alignment: center; }
            }
        }
    }

    // === Global keyboard handler ===
    FocusScope {
        key-pressed(event) => {
            root.key-pressed(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt
            );
            accept
        }
    }
}
