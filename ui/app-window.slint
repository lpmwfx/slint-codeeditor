// AppWindow — MOTHER (demo only)
// Owns all state. Embeds CodeEditorWidget as a stateless child.
// Keyboard handling lives here — it is a window-level concern.
import { CodeEditorWidget, EditorTheme, FlatToken, CodeLine } from "widget.slint";
export { EditorTheme }

export component AppWindow inherits Window {
    title: "Code Editor — Slint";
    width: 960px;
    height: 640px;
    background: EditorTheme.bg-editor;

    // === All state owned here — Rust pushes via set_*() ===
    in property <[CodeLine]>  lines;
    in property <[FlatToken]> all-tokens;
    in property <int>         cursor-line:  0;
    in property <int>         cursor-col:   0;
    in property <float>       char-width:   7.8;
    in property <int>         total-lines:  0;
    in property <string>      status-text:  "Ln 1, Col 1";
    in property <string>      language:     "JavaScript";
    in property <string>      file-name:    "demo.js";

    // === Callbacks to Rust adapter ===
    callback key-pressed(string, bool, bool, bool);
    callback editor-clicked(float, float);
    callback open-file();

    // Title bar — mother owns height
    Rectangle {
        height: 38px;
        background: EditorTheme.bg-titlebar;

        Text {
            text: root.file-name + " — Code Editor";
            color: EditorTheme.text-title;
            font-size: EditorTheme.font-size-ui;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            background: EditorTheme.border-color;
        }
    }

    // Widget child — fills remaining space
    CodeEditorWidget {
        y: 38px;
        width: 100%;
        height: root.height - 38px;

        lines:       root.lines;
        all-tokens:  root.all-tokens;
        cursor-line: root.cursor-line;
        cursor-col:  root.cursor-col;
        char-width:  root.char-width;
        total-lines: root.total-lines;
        status-text: root.status-text;
        language:    root.language;
        file-name:   root.file-name;

        editor-clicked(x, y) => { root.editor-clicked(x, y); }
        open-file => { root.open-file(); }
    }

    // Global keyboard handler — window-level concern, stays in mother
    FocusScope {
        key-pressed(event) => {
            root.key-pressed(
                event.text,
                event.modifiers.control,
                event.modifiers.shift,
                event.modifiers.alt
            );
            accept
        }
    }
}
